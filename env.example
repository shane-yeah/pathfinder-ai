# =============================================
# Pathfinder AI — 環境變數設定範本
# =============================================
# 使用方式：
#   cp .env.example .env
#   然後填入你自己的值
# ⚠️  .env 絕對不可以上傳到 GitHub！
# =============================================

# Gemini API Key（必填）
# 免費申請：https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MCP Server Port（選填，預設 3001）
# MCP_PORT=3001

# Gemini 模型（選填，預設 gemini-2.5-flash）
# 可選：gemini-2.0-flash / gemini-1.5-flash / gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash
